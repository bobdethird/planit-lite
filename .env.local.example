# PlanIt — Environment Variables
# Copy this to .env.local and fill in your keys

# Required: Google Gemini (for video analysis — Stage 1)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Required: Anthropic Claude (for itinerary planning — Stage 2)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# Required for real venue data + interactive map: Google Maps Platform
# Enable: Places API (New), Geocoding API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_maps_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_key_here

# Optional: Google Calendar OAuth credentials
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# Optional: App public URL (used in GCal event deep links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
