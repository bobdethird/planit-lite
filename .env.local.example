# VibeSync — Environment Variables
# Copy this to .env.local and fill in your keys

# Required: Google Gemini (for video analysis + planning agent)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key_here

# Required: ElevenLabs (for audio transcription)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_6ce0499b768f21b28c039d9f065f822ae3714ade3a58bb6e

# Required for real venue data + interactive map: Google Maps Platform
# Enable: Places API (New), Geocoding API, Maps JavaScript API
GOOGLE_MAPS_API_KEY=your_maps_key_here
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_key_here

# Optional: Google Calendar OAuth token (for real GCal write)
GOOGLE_CALENDAR_SERVICE_TOKEN=

# Optional: App public URL (used in GCal event deep links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
