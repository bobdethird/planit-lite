# ElevenLabs — required for /api/transcribe (Scribe)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Google AI (Gemini) — required for /api/analyze and /api/plan
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Public URL for MCP / calendar links (production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: require this header on DELETE /api/events/[id]
# PLANIT_ADMIN_SECRET=
