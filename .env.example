# Gemini — required for /api/analyze (video analysis)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude — required for /api/plan (itinerary generation)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Maps / Places — required for venue data + interactive map
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Public URL for MCP / calendar links (production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: require this header on DELETE /api/events/[id]
# PLANIT_ADMIN_SECRET=
